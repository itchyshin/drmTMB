# History files
.Rhistory
.Rapp.history

# Python bytecode cache (from the tools/*.py validators)
__pycache__/
*.pyc

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata
.DS_Store

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# Compiled objects from local package development
src/*.o
src/*.so
src/*.dll

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site output, while keeping project design notes tracked
docs/*
!docs/design/
!docs/design/**
!docs/dev-log/
!docs/dev-log/**
!docs/course/
!docs/course/**
!docs/agent-kit/
!docs/agent-kit/**
pkgdown-site/

# Local benchmark outputs
bench/*.csv
bench/results/

# Local Codex handoff and stress-test outputs
docs/dev-log/recovery-checkpoints/
docs/dev-log/ayumi-convergence/**/*.csv
docs/dev-log/ayumi-convergence/**/*.rds

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/
/dis_reg_models
/doc/
/Meta/
